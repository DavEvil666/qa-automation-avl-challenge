# API
# URL base de la API bajo prueba (Restful Booker)
API_BASE_URL=https://restful-booker.herokuapp.com

# Appium / dispositivo móvil
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
ANDROID_DEVICE_NAME=Android Emulator

# Kafka / eventos (opcional - bonus)
# Cambiar a true para habilitar la suite de pruebas de eventos
KAFKA_ENABLED=false
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=booking-created